# ─── Graha — Root Environment Variables ──────────────────────
# Copy this file to .env.local and fill in your values.
# Used by the Hono API (apps/api).

# Groq API Key (required for AI-powered horoscope interpretations)
# Get one at https://console.groq.com
GROQ_API_KEY=

# Hugging Face API Token (optional fallback AI provider)
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Neon Database URL (optional — the app works without it)
# Get your free connection string at https://neon.tech
# Format: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Port for local development (default: 3001)
PORT=3001

# API Secret — shared secret between frontend and backend
# The frontend proxy adds this as X-Graha-Secret header (server-side, hidden from browser).
# The backend validates it on every request (except /health).
# In Vercel, set this in both projects (graha-web + graha-api).
# In local dev, leave empty to skip the check.
API_SECRET=

# Axiom API Token — structured logging
# Create a dataset called "lagna" at https://app.axiom.co and paste your API token here
AXIOM_TOKEN=

# ─── Frontend — apps/web/.env.local ──────────────────────────
# The web app needs its own .env.local in apps/web/:
#
#   API_URL=http://localhost:3001
#
# This tells the Next.js proxy route where to forward /api/* requests.
# In production, set API_URL=https://graha-api.vercel.app in Vercel env vars.
