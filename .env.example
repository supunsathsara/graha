# Graha — Environment Variables
# Copy this to .env.local and fill in your values

# Groq API Key (required for AI-powered horoscope interpretations)
# Get one at https://console.groq.com
GROQ_API_KEY=

# Hugging Face API Token (optional fallback provider)
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Neon Database URL
# Get your connection string at https://neon.tech (free tier: 500MB, 100hr compute/month)
# Format: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Port for local development (default: 3001)
PORT=3001
