{
  "name": "graha",
  "private": true,
  "description": "Vedic astrology — monorepo",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "api:dev": "turbo dev --filter=@graha/api",
    "web:dev": "turbo dev --filter=@graha/web",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=18"
  }
}
